# SignAI Backend Configuration

# Model & Checkpoint Paths
MODEL_PATH=checkpoints/best_model.pt
CLASSES_PATH=checkpoints/classes.json

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# CORS Settings
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://0.0.0.0:3000
ALLOWED_METHODS=GET,POST,OPTIONS,PUT,DELETE
ALLOWED_HEADERS=Content-Type,Authorization

# Database (if needed)
DATABASE_URL=sqlite:///./signai.db

# Logging
LOG_LEVEL=INFO
